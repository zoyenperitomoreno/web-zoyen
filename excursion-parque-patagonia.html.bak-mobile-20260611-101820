    {id:"posadas", name:"Lago Posadas y Ruta Escenica 41", aliases:["posadas","lago posadas","ruta 41","ruta escenica"], price:15000, duration:"dia completo (12 hs)", capacity:14, type:"excursion", summary:"recorrido panoramico por lagos, miradores y la Ruta Escenica 41 cerca de Perito Moreno."},
    {id:"zeballos", name:"Ruta 41 y Monte Zeballos", aliases:["zeballos","monte zeballos","ruta 41"], price:16000, duration:"dia completo", capacity:14, type:"excursion", summary:"travesia de altura por estepa, bosque, cordillera y uno de los caminos mas escenicos de Santa Cruz."},
    {id:"charcamata", name:"Alero Charcamata", aliases:["charcamata","alero"], price:12000, duration:"medio dia", capacity:14, type:"excursion", summary:"experiencia vinculada al arte rupestre, patrimonio cultural y paisaje natural de la zona."},
    {id:"parque", name:"Portal Canon Pinturas - Parque Patagonia", aliases:["parque","parque patagonia","canadon","canon","pinturas","portal"], price:8000, duration:"medio dia (5 hs)", capacity:14, type:"excursion", summary:"senderos, fauna, geologia y vistas amplias del noroeste de Santa Cruz."},
    {id:"escension", name:"PNP / Estancia La Escension", aliases:["escension","estancia","la escension","pnp"], price:7000, duration:"medio dia (4 hs)", capacity:14, type:"excursion", summary:"salida corta vinculada al Parque Patagonia y la historia de estancia de la region."}
  ];

  var tours = [
    {id:"patagonia", name:"Patagonia Inedita", aliases:["patagonia inedita","inedita"], price:185000, duration:"6 dias / 5 noches", capacity:14, type:"tour", pdf:"assets/pdfs/patagonia-inedita-itinerario.pdf", summary:"sale desde Comodoro Rivadavia y recorre Perito Moreno, Cueva de las Manos, Parque Patagonia, Los Antiguos, Ruta Escenica 41, Carretera Austral, Puerto Rio Tranquilo y Capillas de Marmol."},
    {id:"carretera", name:"Carretera Austral", aliases:["carretera austral","austral","ohiggins","villa ohiggins","tortel","cochrane"], price:210000, duration:"8 dias / 7 noches", capacity:14, type:"tour", pdf:"assets/pdfs/carretera-austral-itinerario.pdf", summary:"sale desde Perito Moreno e incluye Chile Chico, Cochrane, Caleta Tortel, Villa O'Higgins, Puerto Rio Tranquilo, Capillas de Marmol, Coyhaique y regreso por Paso Huemules."}
  ];

  var allProducts = excursiones.concat(tours);

  function normalize(text){
    return (text || "").toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/&middot;|·/g," ").replace(/[^a-z0-9ñ\s/.-]/g," ").replace(/\s+/g," ").trim();
  }
  function money(n){ return "$" + Number(n || 0).toLocaleString("es-AR") + " AR p/p"; }
  function todayText(){ return new Date().toLocaleDateString("es-AR", { day:"numeric", month:"long", year:"numeric" }); }
  function escapeHtml(text){
    return String(text || '').replace(/[&<>"']/g, function(ch){
      return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[ch];
    });
  }
  function formatZoyiText(text){
    var out = escapeHtml(text);
    out = out.replace(/;\s*/g, '\n- ');
    out = out.replace(/\.\s+(=[A-Z0-9])/g, '.\n');
    out = out.replace(/\n{2,}/g, '\n');
    out = out.replace(/(^|\n)([^\n:<]{3,46}:)/g, '$1<span class="zoyi-answer-title">$2</span>');
    out = out.replace(/\n-\s*([^\n]+)/g, '\n<span class="zoyi-list-line">$1</span>');
    out = out.replace(/\n/g, '<span class="zoyi-soft-break"></span>');
    return out;
  }  function addMessage(text, who){
    if (!messages) return;
    var div = document.createElement("div");
    div.className = "zoyi-msg " + who;
    if (who === "bot") div.innerHTML = formatZoyiText(text); else div.textContent = text;
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }
  function productLine(p){ return p.name + ": " + p.duration + ", " + money(p.price) + ", cupos hasta " + p.capacity + " personas."; }
  function findProduct(q){
    var best = null, score = 0;
    allProducts.forEach(function(p){
      var local = 0;
      [p.name].concat(p.aliases || []).forEach(function(alias){
        alias = normalize(alias);
        if (alias && q.indexOf(alias) !== -1) local += alias.length > 8 ? 3 : 2;
      });
      if (local > score) { best = p; score = local; }
    });
    return best;
  }
  function isAsking(q, words){ return words.some(function(w){ return q.indexOf(normalize(w)) !== -1; }); }
  function listExcursions(){ return "Excursiones de dia o medio dia disponibles: " + excursiones.map(productLine).join(" "); }
  function listTours(){ return "Tours de autor disponibles: " + tours.map(productLine).join(" ") + " Ambos tienen itinerario descargable en PDF desde su pagina."; }
  function pricesAnswer(product){
    if (product) return productLine(product) + " El precio esta expresado en pesos argentinos AR por persona.";
    return "Precios en AR por persona: " + allProducts.map(function(p){ return p.name + " " + money(p.price); }).join("; ") + ".";
  }
  function datesAnswer(product){
    var base = "Las reservas del sitio permiten elegir fecha desde hoy (" + todayText() + ") en adelante. La disponibilidad real se valida por fecha, excursion/tour y cupos.";
    if (product) base += " Para " + product.name + " la capacidad de referencia es de hasta " + product.capacity + " personas.";
    return base + " Si queres reservar, toca Reservar, elegi experiencia, fecha, cantidad de personas y asientos disponibles.";
  }
  function reservationAnswer(){
    return "Para reservar desde la web: 1) toca Reservar, 2) elegi Tour de autor o Excursion, 3) selecciona fecha desde hoy en adelante, 4) indica personas y datos, 5) elegi asiento. La sena se calcula como 20% del total.";
  }
  function locationAnswer(){
    return "Zoyen Turismo esta en Perito Moreno, Santa Cruz, Patagonia Argentina. Desde ahi se operan excursiones a Cueva de las Manos, Parque Patagonia, Ruta 41, Lago Posadas y conexiones hacia Carretera Austral.";
  }
  function humanAnswer(){
    return "Si queres hablar con una persona del equipo, podes usar " + contactText + ". Link directo: " + waLink;
  }
  function compareAnswer(){
    return "Si tenes poco tiempo, mira excursiones de dia: Cueva de las Manos, Capillas de Marmol, Ruta 41, Lago Posadas o Parque Patagonia. Si buscas viaje completo, Patagonia Inedita dura 6 dias y Carretera Austral dura 8 dias. Para arqueologia: Cueva o Charcamata. Para navegacion: Capillas. Para ruta escenica: Ruta 41/Zeballos o Lago Posadas.";
  }
  function pdfAnswer(product){
    if (product && product.pdf) return "El itinerario PDF de " + product.name + " se descarga desde su pagina. Ruta del archivo: " + product.pdf;
    return "Los tours con PDF descargable son Patagonia Inedita y Carretera Austral. En cada pagina hay un boton de descarga del itinerario.";
  }
  function answer(raw){
    var q = normalize(raw);
    if (!q || q.length < 2) return "Preguntame por fechas, disponibilidad, precios, excursiones, tours, ubicacion o reservas.";
    var product = findProduct(q);

    if (isAsking(q, ["persona","humano","asesor","asesora","hablar con alguien","whatsapp","telefono","email","mail","contactar","contacto directo"])) return humanAnswer();
    if (isAsking(q, ["fecha","fechas","disponible","disponibilidad","cupos","lugar","lugares","cuando","calendario"])) return datesAnswer(product);
    if (isAsking(q, ["precio","precios","tarifa","tarifas","valor","valores","cuanto","sale","costo","costos"])) return pricesAnswer(product);
    if (isAsking(q, ["reservar","reserva","reservas","contratar","sena","seña","asiento","asientos","pago"])) return reservationAnswer();
    if (isAsking(q, ["ubicacion","ubicación","donde estan","direccion","dirección","perito moreno","santa cruz","como llegar"])) return locationAnswer();
    if (isAsking(q, ["itinerario","pdf","descargar","programa","recorrido"])) return pdfAnswer(product);
    if (isAsking(q, ["excursion","excursiones","paseos","salidas","dia completo","medio dia"])) return product ? productLine(product) + " " + product.summary : listExcursions();
    if (isAsking(q, ["tour","tours","autor","varios dias","viaje completo","paquete"])) return product ? productLine(product) + " " + product.summary : listTours();
    if (isAsking(q, ["recomendas","recomendacion","conviene","diferencia","comparar","mejor","cual elijo","que hago"])) return compareAnswer();
    if (isAsking(q, ["bienestar","wellness","yoga","masajes"])) return "Turismo de Bienestar es una linea complementaria para sumar pausa, naturaleza y cuidado al viaje. Si buscas algo tranquilo, se puede combinar con excursiones de medio dia o estadias en la zona.";
    if (isAsking(q, ["zoyen","agencia","legajo","quienes","quienes son"])) return "Zoyen Turismo es una agencia local de Perito Moreno, Santa Cruz, legajo 15.625. Disena excursiones y tours de autor en Patagonia.";
    if (product) return productLine(product) + " " + product.summary;

    return "Puedo ayudarte con informacion del sitio: fechas disponibles, precios en AR, cupos, tipos de excursiones, tours de autor, ubicación, itinerarios PDF y como reservar. Proba preguntarme, por ejemplo: 'precio de Capillas', 'fechas para Patagonia Inedita' o 'que excursion me recomendas'.";
  }
  function submit(text){
    var value = (text || (input ? input.value : "") || "").trim();
    if (!value) return;
    addMessage(value, "user");
    if (input) input.value = "";
    window.setTimeout(function(){ addMessage(answer(value), "bot"); }, 160);
  }
  if (toggle) toggle.addEventListener("click", function(){
    widget.classList.toggle("open");
    toggle.setAttribute("aria-expanded", widget.classList.contains("open") ? "true" : "false");
    if (widget.classList.contains("open") && input) input.focus();
  });
  if (closeBtn) closeBtn.addEventListener("click", function(){ widget.classList.remove("open"); if (toggle) toggle.setAttribute("aria-expanded","false"); });
  if (form) form.addEventListener("submit", function(e){ e.preventDefault(); submit(); });
  if (chips) chips.addEventListener("click", function(e){ if (e.target.matches("button")) submit(e.target.textContent); });
  addMessage("Hola, soy Zoyi. Puedo responder sobre excursiones, tours, precios en AR, fechas disponibles, cupos, ubicación e itinerarios. Solo te paso con una persona si me lo pedis.", "bot");
})();
</script>

<script id="zoyen-cta-scroll-motion">
(function(){
  function initCtaNudge(){
    const navActions = document.querySelector('body > nav .nav-actions');
    if (!navActions) return;
    let lastSection = '';
    let pulseTimer = null;
    function pulseActions(){
      navActions.classList.remove('cta-nudge');
      void navActions.offsetWidth;
      navActions.classList.add('cta-nudge');
      clearTimeout(pulseTimer);
      pulseTimer = setTimeout(function(){ navActions.classList.remove('cta-nudge'); }, 1900);
    }
    window.addEventListener('load', function(){ setTimeout(pulseActions, 900); }, { once: true });
    window.setInterval(pulseActions, 5200);
    const sections = document.querySelectorAll('section[id], footer[id], main[id], .hero, .page-hero');
    if (!('IntersectionObserver' in window) || !sections.length) return;
    const observer = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if (!entry.isIntersecting) return;
        const id = entry.target.id || entry.target.className || 'section';
        if (id === lastSection) return;
        lastSection = id;
        pulseActions();
      });
    }, { threshold: 0.45 });
    sections.forEach(function(section){ observer.observe(section); });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initCtaNudge);
  else initCtaNudge();
})();
</script>
