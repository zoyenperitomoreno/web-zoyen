<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Parque Nacional Patagonia – Zoyen Turismo</title>
<link href="https://fonts.googleapis.com/css2family=DM+Serif+Display:ital@0;1&family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
/* Ajuste global de tipografa */
html { font-size: 18px; }

:root {
  --ink:       #1a1410;
  --dark:      #231c14;
  --bark:      #3a2d1f;
  --ember:     #d4772a;
  --ember-dim: #b8621e;
  --amber:     #b87332;
  --sand:      #c9a96e;
  --dust:      #e8dcc8;
  --cream:     #f5f0e8;
  --fog:       #faf7f2;
  --stone:     #7a6a5a;
  --olive:     #5a6040;
  --sky:       #8b9ba8;
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Sora', sans-serif;
  font-size: 16px; line-height: 1.7;
  background: var(--fog); color: var(--ink);
  overflow-x: hidden;
}

/* NAV */
body > nav:not(.breadcrumb) {
  position: fixed; top: 0; left: 0; right: 0; z-index: 900;
  height: 72px;
  display: grid; grid-template-columns: auto auto 1fr auto;
  align-items: center; padding: 0 2vw; gap: 1rem;
  background: rgba(10,10,10,0.92);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(212,119,42,0.20);
}
.nav-logo {
  display: flex; align-items: center; gap: 10px;
  text-decoration: none; line-height: 1; flex-shrink: 0;
}
.nav-emblem { width: 54px; height: 54px; flex-shrink: 0; }
@keyframes nav-rose-spin { to { transform: rotate(360deg); } }
@keyframes nav-ring-ccw  { to { transform: rotate(-360deg); } }
.nav-emblem .nav-rose-anim { transform-origin: 50px 50px; animation: heroRoseSpin 18s linear infinite; animation-delay: -5s; }
.nav-emblem .nav-ring-anim { transform-origin: 50px 50px; animation: heroRingCCW 45s linear infinite; animation-delay: -5s; }
@keyframes heroRingCCW { to { transform: rotate(-360deg); } }
@keyframes heroRoseSpin { to { transform: rotate(360deg); } }
.nav-logo-text { display: flex; flex-direction: column; gap: 2px; justify-content: center; }
.nav-logo .z { font-family: 'Sora',sans-serif; font-weight:700; font-size:1.4rem; letter-spacing:.12em; color:var(--cream); text-transform:uppercase; }
.nav-logo .t { font-family: 'Sora',sans-serif; font-weight:700; font-size:1.4rem; letter-spacing:.12em; color:var(--ember); text-transform:uppercase; }
.nav-logo sub { font-size:.60rem; font-weight:400; letter-spacing:.2em; color:var(--sand); opacity:.65; text-transform:uppercase; display:block; line-height:1.4; }
.nav-links { display:flex; gap:1.2rem; list-style:none; align-items:center; justify-content:center; }
.nav-links a { color:rgba(245,240,232,.75); text-decoration:none; font-size:.78rem; font-weight:500; letter-spacing:.06em; text-transform:uppercase; transition:color .2s; position:relative; white-space:nowrap; }
.nav-links a::after { content:''; position:absolute; bottom:-4px; left:0; right:0; height:1px; background:var(--ember); transform:scaleX(0); transform-origin:left; transition:transform .3s; }
.nav-links a:hover { color:var(--cream); }
.nav-links a:hover::after { transform:scaleX(1); }
.nav-cta-btn { background:var(--ember); color:var(--cream); padding:.5rem 1.3rem; border-radius:2px; font-family:'Sora',sans-serif; font-size:.78rem; font-weight:600; letter-spacing:.15em; text-transform:uppercase; text-decoration:none; white-space:nowrap; flex-shrink:0; transition:background .2s; border:none; cursor:pointer; }
.nav-cta-btn:hover { background:var(--ember-dim); }
@media(max-width:960px){ .nav-links { display:none; } body > nav:not(.breadcrumb) { grid-template-columns: auto auto 1fr; } }

/* HERO EXCURSION */
.exc-hero {
  position: relative;
  height: 60vh; min-height: 380px;
  overflow: hidden;
  display: flex; align-items: flex-end;
  padding-bottom: 3rem;
}
.exc-hero-bg {
  position: absolute; inset: 0;
  background-image: url('assets/pps.jpg');
  background-size: cover; background-position: center;
}
.exc-hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(26,20,16,.15) 0%, rgba(26,20,16,.0) 40%, rgba(26,20,16,.7) 80%, rgba(26,20,16,.9) 100%);
}
.exc-hero-content {
  position: relative; z-index: 2;
  padding: 0 5vw; color: var(--cream);
  max-width: 900px;
}
.exc-tag {
  display: inline-block;
  background: var(--ember); color: var(--cream);
  font-size: .72rem; font-weight: 700; letter-spacing: .22em; text-transform: uppercase;
  padding: .3rem .9rem; margin-bottom: 1rem;
  border-radius: 1px;
}
.exc-hero-title {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(2rem, 5vw, 3.8rem);
  font-weight: 600; line-height: 1.1;
  text-shadow: 0 2px 20px rgba(26,20,16,.5);
}
.exc-hero-title em { font-style:italic; color:var(--sand); }

/* BREADCRUMB */
.breadcrumb {
  background: var(--dark); border-bottom: 1px solid rgba(212,119,42,.15);
  padding: .8rem 5vw;
}
.breadcrumb a { color: var(--sand); text-decoration: none; font-size:.78rem; letter-spacing:.1em; }
.breadcrumb a:hover { color: var(--ember); }
.breadcrumb span { color: var(--stone); font-size:.78rem; margin: 0 .5rem; }

/* CONTENT LAYOUT */
.exc-body {
  max-width: 1100px; margin: 0 auto;
  padding: 4rem 5vw 5rem;
  display: grid; grid-template-columns: 1fr 340px; gap: 4rem;
}
@media(max-width:860px){ .exc-body { grid-template-columns: 1fr; } }

.exc-main h2 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(1.5rem,3vw,2.2rem); color: var(--ink);
  margin-bottom: 1.2rem; margin-top: 2.4rem;
}
.exc-main h2:first-child { margin-top: 0; }
.exc-main h3 {
  font-size: 1rem; font-weight: 700; letter-spacing: .15em; text-transform: uppercase;
  color: var(--ember); margin-bottom: .8rem; margin-top: 2rem;
}
.exc-main p { color: var(--stone); line-height: 1.8; margin-bottom: 1rem; }
.exc-main strong { color: var(--ink); }
.exc-main ul { padding-left: 1.4rem; color: var(--stone); line-height: 1.8; margin-bottom: 1rem; }
.exc-main ul li { margin-bottom: .4rem; }
.exc-main .note {
  background: rgba(212,119,42,.07); border-left: 3px solid var(--ember);
  padding: 1rem 1.2rem; border-radius: 2px; margin: 1.5rem 0;
  color: var(--ink); font-size: .93rem;
}
.exc-main .warn {
  background: rgba(90,96,64,.08); border-left: 3px solid var(--olive);
  padding: 1rem 1.2rem; border-radius: 2px; margin: 1.5rem 0;
  color: var(--ink); font-size: .93rem;
}

/* SIDEBAR */
.exc-sidebar { display: flex; flex-direction: column; gap: 1.5rem; }
.exc-card {
  background: var(--dark); color: var(--cream);
  border-radius: 3px; overflow: hidden;
  border: 1px solid rgba(212,119,42,.15);
}
.exc-card-head {
  padding: 1.2rem 1.4rem .6rem;
  font-family: 'DM Serif Display',serif;
  font-size: 1.2rem; color: var(--sand);
}
.exc-card-body { padding: .4rem 1.4rem 1.4rem; }
.exc-card-body p { color: rgba(245,240,232,.7); font-size: .9rem; line-height: 1.7; margin-bottom: .6rem; }
.exc-card-body .price {
  font-size: 1.4rem; font-weight: 700; color: var(--ember);
  margin: .8rem 0 .2rem;
}
.exc-card-body .price-label { font-size: .75rem; color: var(--stone); letter-spacing: .1em; }
.btn-reservar {
  display: block; width: 100%;
  background: var(--ember); color: var(--cream);
  text-align: center; padding: .85rem 1rem;
  border-radius: 2px; text-decoration: none;
  font-weight: 700; font-size: .85rem; letter-spacing: .2em; text-transform: uppercase;
  transition: background .2s; margin-top: 1rem;
  border: none; cursor: pointer; font-family: 'Sora',sans-serif;
}
.btn-reservar:hover { background: var(--ember-dim); }
.exc-detail-list {
  list-style: none; padding: 0;
  display: flex; flex-direction: column; gap: .5rem;
}
.exc-detail-list li {
  display: flex; align-items: flex-start; gap: .6rem;
  font-size: .88rem; color: rgba(245,240,232,.7);
}
.exc-detail-list li .icon { color: var(--ember); flex-shrink: 0; font-size:1rem; }

/* VIDEO */
.video-wrap {
  position: relative; padding-bottom: 56.25%;
  height: 0; overflow: hidden; border-radius: 3px;
  margin: 2rem 0;
}
.video-wrap iframe {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%; border: 0;
}

/* OTHER EXCURSIONS */
.more-excursiones {
  background: var(--dark);
  padding: 4rem 5vw;
  border-top: 1px solid rgba(212,119,42,.12);
}
.more-excursiones h2 {
  font-family: 'DM Serif Display',serif;
  font-size: 1.8rem; color: var(--cream);
  margin-bottom: 2rem;
}
.exc-mini-grid {
  display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem;
}
@media(max-width:860px){ .exc-mini-grid { grid-template-columns: repeat(2,1fr); } }
@media(max-width:560px){ .exc-mini-grid { grid-template-columns: 1fr; } }
.exc-mini {
  position: relative; border-radius: 3px; overflow: hidden;
  aspect-ratio: 4/3; text-decoration: none;
  display: block;
}
.exc-mini img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform .5s;
}
.exc-mini:hover img { transform: scale(1.05); }
.exc-mini-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(26,20,16,.85) 0%, transparent 50%);
  display: flex; align-items: flex-end;
  padding: .9rem;
}
.exc-mini-name {
  color: var(--cream); font-weight: 600;
  font-size: .82rem; letter-spacing: .04em; line-height: 1.3;
}

/* FOOTER */
footer {
  background: var(--dark);
  border-top: 1px solid rgba(212,119,42,.2);
  padding: 3rem 5vw 1.5rem;
}
.footer-top {
  display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: 3rem;
  margin-bottom: 2.5rem;
}
@media(max-width:760px){ .footer-top { grid-template-columns: 1fr; gap: 2rem; } }
.footer-brand-wrap { display:flex; align-items:center; gap:.8rem; margin-bottom:1rem; }
.footer-emblem { width:48px; height:48px; flex-shrink:0; }
@keyframes heroRingCW { to { transform: rotate(360deg); } }
.ft-ring-anim { transform-origin:50px 50px; animation:heroRingCCW 45s linear infinite; }
.ft-rose-anim { transform-origin:50px 50px; animation:heroRoseSpin 18s linear infinite; }
.footer-brand { font-family:'Sora',sans-serif; font-weight:700; font-size:1.1rem; letter-spacing:.1em; text-transform:uppercase; }
.footer-brand span { color:var(--sand); }
.footer-brand-zoyen { color:var(--cream) !important; }
.footer-tagline { color:var(--stone); font-size:.85rem; line-height:1.6; margin-bottom:1.2rem; }
.socials { display:flex; gap:.6rem; }
.social-btn { display:flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:2px; background:rgba(255,255,255,.06); color:var(--sand); text-decoration:none; transition:background .2s,color .2s; }
.social-btn:hover { background:var(--ember); color:var(--cream); }
.footer-col-title { font-size:.72rem; font-weight:700; letter-spacing:.22em; text-transform:uppercase; color:var(--ember); margin-bottom:.9rem; }
.footer-links { list-style:none; display:flex; flex-direction:column; gap:.45rem; }
.footer-links a { color:var(--stone); text-decoration:none; font-size:.88rem; transition:color .2s; }
.footer-links a:hover { color:var(--sand); }
.footer-contact { color:var(--stone); font-size:.88rem; line-height:1.8; }
.footer-bottom { border-top:1px solid rgba(201,169,110,.1); padding-top:1.2rem; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:.5rem; }
.footer-bottom span, .footer-bottom a { color:var(--stone); font-size:.78rem; text-decoration:none; }
.footer-bottom a:hover { color:var(--sand); }

/* WA float */
.wa {
  position: fixed; bottom: 1.8rem; right: 1.8rem; z-index: 800;
  width: 52px; height: 52px;
  background: #25d366; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 16px rgba(0,0,0,.25);
  transition: transform .2s;
}
.wa:hover { transform: scale(1.1); }

/* LANGUAGE SWITCHER */
.lang-switcher { position: relative; justify-self: start; z-index: 920; }
.lang-current {
  min-width: 116px; height: 34px;
  display: inline-flex; align-items: center; justify-content: space-between; gap: .55rem;
  padding: 0 .7rem;
  border: 1px solid rgba(212,119,42,.34); border-radius: 2px;
  background: rgba(245,240,232,.06); color: rgba(245,240,232,.78);
  font-family: 'Sora', sans-serif; font-size: .68rem; font-weight: 700;
  letter-spacing: .08em; text-transform: uppercase; cursor: pointer;
  transition: border-color .2s, background .2s, color .2s;
}
.lang-current:hover,
.lang-switcher.open .lang-current { color: var(--cream); border-color: rgba(212,119,42,.65); background: rgba(212,119,42,.12); }
.lang-current::after {
  content: ''; width: 6px; height: 6px;
  border-right: 1px solid currentColor; border-bottom: 1px solid currentColor;
  transform: translateY(-2px) rotate(45deg); transition: transform .2s;
}
.lang-switcher.open .lang-current::after { transform: translateY(1px) rotate(225deg); }
.lang-menu {
  position: absolute; top: calc(100% + 8px); left: 0; min-width: 168px;
  padding: 6px; list-style: none;
  background: rgba(10,10,10,.96);
  border: 1px solid rgba(212,119,42,.28); border-radius: 2px;
  box-shadow: 0 14px 36px rgba(0,0,0,.35);
  opacity: 0; visibility: hidden; transform: translateY(-6px);
  transition: opacity .18s, transform .18s, visibility .18s;
}
.lang-switcher.open .lang-menu { opacity: 1; visibility: visible; transform: translateY(0); }
.lang-btn {
  width: 100%; display: flex; align-items: center; justify-content: space-between; gap: .75rem;
  padding: .55rem .65rem; border: 0; border-radius: 1px;
  background: transparent; color: rgba(245,240,232,.68);
  font-family: 'Sora', sans-serif; font-size: .7rem; font-weight: 600;
  letter-spacing: .04em; cursor: pointer; text-align: left;
  transition: background .2s, color .2s;
}
.lang-btn:hover { color: var(--cream); background: rgba(212,119,42,.16); }
.lang-btn.active { background: var(--ember); color: var(--cream); }
.lang-code { color: rgba(245,240,232,.45); font-size: .58rem; font-weight: 800; letter-spacing: .1em; }
.lang-btn.active .lang-code { color: rgba(255,255,255,.82); }
@media (min-width: 961px) and (max-width: 1360px) {
  nav { column-gap: .75rem; }
  .nav-emblem { width: 46px; height: 46px; }
  .nav-logo { gap: 8px; }
  .nav-logo .z, .nav-logo .t { font-size: 1.08rem; letter-spacing: .09em; }
  .nav-logo sub { display: none; }
  .nav-links { gap: .72rem; }
  .nav-links a { font-size: .64rem; letter-spacing: .035em; }
  .lang-current { min-width: 98px; height: 31px; padding: 0 .55rem; font-size: .58rem; }
  .lang-menu { min-width: 150px; }
  .lang-btn { padding: .5rem .58rem; font-size: .64rem; }
  .nav-cta-btn { padding: .45rem .85rem; font-size: .66rem; letter-spacing: .1em; }
}
@media (max-width: 640px) {
  .nav-cta-btn { display: none; }
  .lang-switcher { margin-left: auto; justify-self: end; }
  .lang-current { min-width: 104px; height: 32px; padding: 0 .55rem; font-size: .58rem; }
  .lang-menu { left: auto; right: 0; min-width: 150px; }
  .lang-btn { padding: .52rem .58rem; font-size: .64rem; }
  .nav-emblem { width: 40px; height: 40px; }
  .nav-logo { gap: 6px; }
  .nav-logo .z, .nav-logo .t { font-size: .98rem; letter-spacing: .08em; }
  .nav-logo sub { display: none; }
}

/* NAV CONTACT + ZOYI ASSISTANT */
.nav-actions {
  display: flex;
  align-items: center;
  justify-self: end;
  gap: .55rem;
  min-width: 0;
}
.nav-contact-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: .45rem;
  min-height: 36px;
  padding: .48rem .95rem;
  border: 1px solid rgba(37,211,102,.58);
  border-radius: 2px;
  background: rgba(37,211,102,.10);
  color: var(--cream);
  font-family: 'Sora', sans-serif;
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .11em;
  line-height: 1;
  text-transform: uppercase;
  text-decoration: none;
  white-space: nowrap;
  transition: background .2s, border-color .2s, color .2s, transform .2s;
}
.nav-contact-btn svg { width: 16px; height: 16px; fill: currentColor; flex: 0 0 auto; }
.nav-contact-btn:hover { background: #25d366; border-color: #25d366; color: #122118; transform: translateY(-1px); }
.zoyi-widget {
  position: fixed;
  right: 22px;
  bottom: 22px;
  z-index: 1600;
  font-family: 'Sora', sans-serif;
}
.zoyi-toggle {
  min-width: 112px;
  height: 54px;
  border: 1px solid rgba(212,119,42,.58);
  border-radius: 999px;
  background: rgba(26,20,16,.92);
  color: var(--cream);
  box-shadow: 0 18px 42px rgba(0,0,0,.32);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: .55rem;
  cursor: pointer;
  transition: transform .2s, background .2s, border-color .2s;
}
.zoyi-toggle:hover { transform: translateY(-2px); border-color: var(--ember); background: rgba(48,34,25,.96); }
.zoyi-toggle svg { width: 19px; height: 19px; stroke: currentColor; fill: none; stroke-width: 1.8; }
.zoyi-toggle strong { font-size: .82rem; letter-spacing: .14em; text-transform: uppercase; }
.zoyi-panel {
  position: absolute;
  right: 0;
  bottom: 68px;
  width: min(360px, calc(100vw - 28px));
  max-height: min(620px, calc(100vh - 110px));
  display: none;
  overflow: hidden;
  border: 1px solid rgba(212,119,42,.32);
  border-radius: 8px;
  background: rgba(245,240,232,.98);
  color: #251d17;
  box-shadow: 0 24px 60px rgba(0,0,0,.34);
}
.zoyi-widget.open .zoyi-panel { display: flex; flex-direction: column; }
.zoyi-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 1rem;
  background: #1f1813;
  color: var(--cream);
}
.zoyi-title { display: flex; flex-direction: column; gap: .18rem; }
.zoyi-title strong { font-size: .88rem; letter-spacing: .14em; text-transform: uppercase; }
.zoyi-title span { font-family: 'Inter', sans-serif; font-size: .74rem; color: rgba(245,240,232,.68); }
.zoyi-close {
  width: 34px;
  height: 34px;
  border: 1px solid rgba(245,240,232,.18);
  border-radius: 50%;
  background: transparent;
  color: var(--cream);
  cursor: pointer;
  font-size: 1.2rem;
  line-height: 1;
}
.zoyi-messages {
  padding: .95rem;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: .7rem;
}
.zoyi-msg {
  max-width: 92%;
  padding: .72rem .82rem;
  border-radius: 8px;
  font-family: 'Inter', sans-serif;
  font-size: .88rem;
  line-height: 1.45;
}
.zoyi-msg.bot { align-self: flex-start; background: #fff; border: 1px solid rgba(37,29,23,.10); }
.zoyi-msg.user { align-self: flex-end; background: #d4772a; color: #fffaf1; }
/* Zoyi legibilidad: respuestas con aire y listas claras */
.zoyi-msg {
  white-space: normal;
  overflow-wrap: break-word;
}
.zoyi-msg.bot {
  max-width: min(96%, 430px);
  line-height: 1.62;
  color: #2d241d;
}
.zoyi-msg .zoyi-answer-title {
  display: block;
  font-family: 'Sora', sans-serif;
  font-size: .72rem;
  font-weight: 800;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: #8a4b1c;
  margin: .1rem 0 .42rem;
}
.zoyi-msg .zoyi-list-line {
  display: block;
  padding: .42rem 0 .42rem .72rem;
  margin-top: .18rem;
  border-top: 1px solid rgba(37,29,23,.08);
  position: relative;
}
.zoyi-msg .zoyi-list-line::before {
  content: '';
  position: absolute;
  left: 0;
  top: 1.08em;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: #d4772a;
}
.zoyi-msg .zoyi-soft-break {
  display: block;
  height: .36rem;
}
.zoyi-chip-row { display: flex; flex-wrap: wrap; gap: .42rem; padding: 0 .95rem .82rem; }
.zoyi-chip {
  border: 1px solid rgba(212,119,42,.28);
  border-radius: 999px;
  background: #fff;
  color: #3a2a20;
  padding: .42rem .62rem;
  font-family: 'Inter', sans-serif;
  font-size: .76rem;
  cursor: pointer;
}
.zoyi-form { display: flex; gap: .5rem; padding: .82rem; border-top: 1px solid rgba(37,29,23,.12); background: #fbf7f0; }
.zoyi-input {
  flex: 1;
  min-width: 0;
  border: 1px solid rgba(37,29,23,.18);
  border-radius: 5px;
  padding: .72rem .78rem;
  font-family: 'Inter', sans-serif;
  font-size: .88rem;
