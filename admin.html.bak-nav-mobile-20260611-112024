function doLogin() {
  const u = document.getElementById('admUser').value.trim();
  const p = document.getElementById('admPass').value;
  if(u===CREDS.user && p===CREDS.pass) {
    loggedIn = true;
    document.getElementById('admLoginErr').style.display = 'none';
    document.getElementById('admLoginWrap').classList.remove('open');
    document.getElementById('panelWrap').style.display = 'block';
    initPanel();
  } else {
    document.getElementById('admLoginErr').style.display = 'block';
    document.getElementById('admPass').value = '';
  }
}

