function saveExc(i) {
  excData[i].precio = parseInt(document.getElementById('exc-precio-'+i).value) || 0;
  excData[i].estado = document.getElementById('exc-estado-'+i).value;
  buildExcursiones();
  showToast('ExcursiГѓВіn actualizada.');
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Disponibilidad ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
function getTourConfigAdmin() { return JSON.parse(JSON.stringify(getTourConfig())); }
function tourLabel(key, t) { return (t.name || key) + ' - ' + (t.duration || ''); }

function buildAvailability() {
  const cfg = getTourConfigAdmin();
  const opts = Object.keys(cfg).map(k => `<option value="${k}">${tourLabel(k,cfg[k])}</option>`).join('');
  document.getElementById('av-tour').innerHTML = opts;
  document.getElementById('blk-tour').innerHTML = opts;
  document.getElementById('av-vehicle').innerHTML = Object.keys(VEHICLE_OPTIONS).map(k => `<option value="${k}">${VEHICLE_OPTIONS[k].name}</option>`).join('');
  refreshAvailabilityAdmin();
  refreshBlockDateOptions();
}
function refreshAvailabilityAdmin() {
  const cfg = getTourConfigAdmin();
  const key = document.getElementById('av-tour').value || Object.keys(cfg)[0];
  const t = cfg[key];
  const list = document.getElementById('av-date-list');
  if(t) {
    document.getElementById('av-price').value = t.precio || 0;
    document.getElementById('av-capacity').value = t.capacity || 16;
    document.getElementById('av-vehicle').value = t.vehicle || 'renault_master';
    updateVehicleAdminPreview();
  }
  if(!t || !t.dates || !t.dates.length) { list.innerHTML='<span class="empty">Sin fechas cargadas.</span>'; return; }
  list.innerHTML = t.dates.slice().sort().map(d => `<span class="date-pill">${new Date(d+'T12:00:00').toLocaleDateString('es-AR',{day:'2-digit',month:'long',year:'numeric'})}<button onclick="removeAvailabilityDate('${key}','${d}')">ГѓвЂ”</button></span>`).join('');
}
function updateVehicleAdminPreview() {
  const key = document.getElementById('av-vehicle').value || 'renault_master';
  const v = VEHICLE_OPTIONS[key] || VEHICLE_OPTIONS.renault_master;
  document.getElementById('av-vehicle-icon').innerHTML = vehicleSvg(v.icon);
  document.getElementById('av-vehicle-name').textContent = v.name + ' - capacidad sugerida ' + v.capacity;
}
function saveAvailabilityConfig() {
  const cfg = getTourConfigAdmin();
  const key = document.getElementById('av-tour').value;
  cfg[key].precio = parseInt(document.getElementById('av-price').value) || 0;
  cfg[key].capacity = parseInt(document.getElementById('av-capacity').value) || 16;
  cfg[key].vehicle = document.getElementById('av-vehicle').value || 'renault_master';
  saveTourConfig(cfg);
  showToast('ConfiguraciГѓВіn guardada.');
}
function addAvailabilityDate() {
  const cfg = getTourConfigAdmin();
  const key = document.getElementById('av-tour').value;
  const d = document.getElementById('av-new-date').value;
  if(!key || !d) return;
  cfg[key].dates = cfg[key].dates || [];
  if(!cfg[key].dates.includes(d)) cfg[key].dates.push(d);
  saveTourConfig(cfg);
  document.getElementById('av-new-date').value = '';
  refreshAvailabilityAdmin();
  refreshBlockDateOptions();
  showToast('Fecha agregada.');
}
function removeAvailabilityDate(key, d) {
  const cfg = getTourConfigAdmin();
  cfg[key].dates = (cfg[key].dates||[]).filter(x=>x!==d);
  saveTourConfig(cfg);
  refreshAvailabilityAdmin();
  showToast('Fecha eliminada.');
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Bloqueo de asientos ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
function refreshBlockDateOptions() {
  const cfg = getTourConfigAdmin();
  const key = document.getElementById('blk-tour').value || Object.keys(cfg)[0];
  const dates = (cfg[key]?.dates||[]).slice().sort();
  document.getElementById('blk-date').innerHTML = dates.map(d => `<option value="${d}">${new Date(d+'T12:00:00').toLocaleDateString('es-AR',{day:'2-digit',month:'long',year:'numeric'})}</option>`).join('') || '<option value="">Sin fechas</option>';
  renderManualSeatGrid();
}
function reservedSeatsForAdmin(key, date) {
  return readReservas().filter(r => (r.excursionKey||'')===key && r.fecha===date && r.estado!=='cancelada').flatMap(r => String(r.asientos||'').split(/[^0-9]+/).map(Number).filter(Boolean));
}
function renderManualSeatGrid() {
  const cfg = getTourConfigAdmin();
  const key = document.getElementById('blk-tour').value;
  const date = document.getElementById('blk-date').value;
  const grid = document.getElementById('manual-seat-grid');
  if(!key || !date) { grid.innerHTML='<div class="empty">CargГѓВЎ una fecha para bloquear asientos.</div>'; return; }
  const manual = ((cfg[key].blockedSeats||{})[date]||[]).map(Number);
  const reserved = reservedSeatsForAdmin(key, date);
  grid.innerHTML = Array.from({length:16},(_,i)=>i+1).map(n => {
    const isReserved = reserved.includes(n);
    return `<label class="manual-seat ${isReserved?'reserved':''}">
      <input type="checkbox" value="${n}" ${manual.includes(n)?'checked':''} ${isReserved?'disabled':''}>
      ${n}
    </label>`;
  }).join('');
}
function saveManualSeats() {
  const cfg = getTourConfigAdmin();
  const key = document.getElementById('blk-tour').value;
  const date = document.getElementById('blk-date').value;
  if(!key || !date) return;
  cfg[key].blockedSeats = cfg[key].blockedSeats || {};
  cfg[key].blockedSeats[date] = Array.from(document.querySelectorAll('#manual-seat-grid input:checked')).map(i=>parseInt(i.value,10)).sort((a,b)=>a-b);
  saveTourConfig(cfg);
  showToast('Asientos bloqueados actualizados.');
}
function clearManualSeats() {
  const cfg = getTourConfigAdmin();
  const key = document.getElementById('blk-tour').value;
  const date = document.getElementById('blk-date').value;
  if(!key || !date) return;
  cfg[key].blockedSeats = cfg[key].blockedSeats || {};
  cfg[key].blockedSeats[date] = [];
  saveTourConfig(cfg);
  renderManualSeatGrid();
  showToast('Asientos liberados.');
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Reservas ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
function buildReservas() {
  const reservas = readReservas();
  const filter = document.getElementById('res-filter').value;
  const list = filter==='all' ? reservas : reservas.filter(r=>r.estado===filter);
  const tb = document.getElementById('r-tbody');
  if(!list.length) { tb.innerHTML=`<tr><td colspan="11" class="empty">${reservas.length?'Sin resultados para ese filtro.':'Sin reservas aГѓВєn.'}</td></tr>`; return; }
  tb.innerHTML = list.slice().reverse().map(r => {
    const idx = reservas.indexOf(r);
    const waMsg = encodeURIComponent('Hola '+r.nombre+', te escribimos desde Zoyen Turismo. Vimos que iniciaste una reserva para '+r.excursion+' y quedГѓВі sin confirmar. Г‚ВїQuerГѓВ©s que te ayudemos a completarla?');
    const waUrl = 'https://wa.me/'+r.tel.replace(/\D/g,'')+'?text='+waMsg;
    const puedeRetarget = (r.estado==='pendiente'||r.estado==='pago_iniciado') && r.tel;
    return `<tr>
      <td style="color:var(--stone)">#${idx+1}</td>
      <td style="font-weight:500">${r.nombre}</td>
      <td style="font-size:12px;color:var(--stone)">${r.tel||'Гўв‚¬вЂњ'}<br>${r.email||'Гўв‚¬вЂњ'}</td>
      <td>${r.excursion}</td>
      <td>${r.fecha?new Date(r.fecha+'T12:00:00').toLocaleDateString('es-AR',{day:'2-digit',month:'2-digit',year:'numeric'}):''}</td>
      <td style="text-align:center">${r.personas}</td>
      <td style="text-align:center">${r.asientos||'Гўв‚¬вЂњ'}</td>
      <td style="color:var(--ember);font-weight:600">$${(r.senia||0).toLocaleString('es-AR')}</td>
      <td>${badge(r.estado)}</td>
      <td style="font-size:11px;color:var(--muted)">${r.ultimoIntento||r.creado||'Гўв‚¬вЂњ'}</td>
      <td><div style="display:flex;gap:5px;flex-wrap:wrap;align-items:center">
        ${puedeRetarget?`<a href="${waUrl}" target="_blank" class="btn btn-wa btn-sm">WA</a>`:''}
        ${r.estado!=='confirmada'?`<button class="btn btn-p btn-sm" onclick="cambiarEstado(${idx},'confirmada')">ГўЕ“вЂњ</button>`:''}
        ${r.estado!=='cancelada'?`<button class="btn btn-d btn-sm" onclick="cambiarEstado(${idx},'cancelada')">ГўЕ“вЂў</button>`:''}
      </div></td>
    </tr>`;
  }).join('');
}
function cambiarEstado(idx, estado) {
  const reservas = readReservas();
  reservas[idx].estado = estado;
  writeReservas(reservas);
  buildReservas();
  buildDashboard();
  showToast('Estado actualizado.');
}
function getReservas() { return readReservas(); }
