function buildSlides() {
  // Lenticular toggle
  let enabled = true;
  try { enabled = localStorage.getItem('lentEnabled') !== 'false'; } catch(e) {}
  const cb = document.getElementById('lent-toggle');
  if(cb) { cb.checked = enabled; cb.onchange = () => { try { localStorage.setItem('lentEnabled', cb.checked); } catch(e) {} showToast('Efecto ' + (cb.checked ? 'activado' : 'desactivado') + '.'); }; }

  document.getElementById('slider-grid').innerHTML = slideLabels.map((lbl, i) => {
    let url = '';
    try { url = localStorage.getItem('zoyen_slide_img_'+i) || ''; } catch(e) {}
    const s = slideDefaults[i];
    return `<div class="slide-card">
      <img class="slide-img" id="sp-${i}" src="${url}" onerror="this.style.background='rgba(255,255,255,.06)'"/>
      <div class="slide-name">${lbl}</div>
      <div class="slide-fields">
        <input type="text" id="t-s${i}-ey" value="${s.ey}" placeholder="Eyebrow"/>
        <input type="text" id="t-s${i}-ti" value="${s.ti}" placeholder="TГѓВ­tulo"/>
        <input type="text" id="t-s${i}-de" value="${s.de}" placeholder="DescripciГѓВіn"/>
        <div style="display:flex;gap:6px;margin-top:4px">
          <input type="text" id="img-${i}" placeholder="URL de imagen" style="flex:1" value="${url}"/>
          <button class="btn btn-p btn-sm" onclick="applyImg(${i},document.getElementById('img-${i}').value)">Aplicar</button>
        </div>
        <button class="btn btn-outline btn-sm" onclick="saveSlideText(${i})">Guardar texto</button>
      </div>
    </div>`;
  }).join('');
}

function applyImg(i, url) {
  try { localStorage.setItem('zoyen_slide_img_'+i, url); } catch(e) {}
  document.getElementById('sp-'+i).src = url;
  showToast('Banner ' + (i+1) + ' actualizado.');
}
function saveSlideText(i) {
  showToast('Slide ' + (i+1) + ' guardado (los textos se editan directamente en index.html).');
