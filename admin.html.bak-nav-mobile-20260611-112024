function buildExcursiones() {
  document.getElementById('exc-list').innerHTML = excData.map((e, i) => `<div class="card">
    <div class="card-title">${e.name}</div>
    <div class="field"><label>Precio ($)</label><input type="number" id="exc-precio-${i}" value="${e.precio}" min="0"/></div>
    <div class="field"><label>Estado</label>
      <select id="exc-estado-${i}">
        <option value="activa" ${e.estado==='activa'?'selected':''}>Activa</option>
        <option value="pausada" ${e.estado==='pausada'?'selected':''}>Pausada</option>
        <option value="completa" ${e.estado==='completa'?'selected':''}>Completa</option>
      </select>
    </div>
    <button class="btn btn-p btn-sm" onclick="saveExc(${i})">Guardar</button>
  </div>`).join('');

  const m = { activa:'bg', pausada:'by', completa:'br' };
  document.getElementById('exc-preview').innerHTML = excData.map(e => `<tr>
    <td style="font-weight:500">${e.name}</td>
    <td style="color:var(--ember);font-weight:600">$${e.precio.toLocaleString('es-AR')}</td>
    <td><span class="badge ${m[e.estado]||'by'}">${e.estado}</span></td>
    <td style="color:var(--muted)">${e.duracion}</td>
