function buildDashboard() {
  const reservas = readReservas();
  const total = reservas.length;
  const pend = reservas.filter(r => r.estado==='pendiente').length;
  const iniciados = reservas.filter(r => r.estado==='pago_iniciado').length;
  const conf = reservas.filter(r => r.estado==='confirmada').length;
  document.getElementById('d-total').textContent = total;
  document.getElementById('d-pend').textContent = pend + iniciados;
  document.getElementById('d-conf').textContent = conf;
  document.getElementById('d-abandon').textContent = iniciados;
  const tb = document.getElementById('d-tbody');
  if(!total) { tb.innerHTML='<tr><td colspan="7" class="empty">Sin reservas registradas aГѓВєn.</td></tr>'; return; }
  tb.innerHTML = reservas.slice(-8).reverse().map((r,i) => `<tr>
    <td style="color:var(--stone)">#${reservas.length-i}</td>
    <td style="font-weight:500">${r.nombre}</td>
    <td>${r.excursion}</td>
    <td>${r.fecha ? new Date(r.fecha+'T12:00:00').toLocaleDateString('es-AR',{day:'numeric',month:'short'}) : ''}</td>
    <td style="text-align:center">${r.personas}</td>
    <td style="color:var(--ember);font-weight:600">$${(r.senia||0).toLocaleString('es-AR')}</td>
    <td>${badge(r.estado)}</td>
  </tr>`).join('');
}

function badge(e) {
  const m = { pendiente:'by', pago_iniciado:'bo', confirmada:'bg', cancelada:'br' };
  const labels = { pendiente:'pendiente', pago_iniciado:'pago iniciado', confirmada:'confirmada', cancelada:'cancelada' };
  return `<span class="badge ${m[e]||'by'}">${labels[e]||e}</span>`;
}

