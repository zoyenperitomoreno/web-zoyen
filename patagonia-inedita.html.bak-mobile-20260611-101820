<script>
(function(){
  document.documentElement.classList.add('js-ready');
  const fallbackByHint = [
    ['capillas', 'https://images.unsplash.com/photo-1500530855697-b586d89ba3eew=1200&q=80'],
    ['marmol', 'https://images.unsplash.com/photo-1500530855697-b586d89ba3eew=1200&q=80'],
    ['cueva', 'https://images.unsplash.com/photo-1501785888041-af3ef285b470w=1200&q=80'],
    ['manos', 'https://images.unsplash.com/photo-1501785888041-af3ef285b470w=1200&q=80'],
    ['ruta', 'https://images.unsplash.com/photo-1500534314209-a25ddb2bd429w=1200&q=80'],
    ['zeballos', 'https://images.unsplash.com/photo-1500534314209-a25ddb2bd429w=1200&q=80'],
    ['posadas', 'https://images.unsplash.com/photo-1500530855697-b586d89ba3eew=1200&q=80'],
    ['patagonia', 'https://images.unsplash.com/photo-1501854140801-50d01698950bw=1200&q=80'],
    ['carretera', 'https://images.unsplash.com/photo-1500534314209-a25ddb2bd429w=1200&q=80'],
    ['parque', 'https://images.unsplash.com/photo-1501785888041-af3ef285b470w=1200&q=80']
  ];
  const genericFallback = 'https://images.unsplash.com/photo-1501854140801-50d01698950bw=1200&q=80';
  function pickFallback(text){
    const haystack = (text || '').toLowerCase();
    const found = fallbackByHint.find(([hint]) => haystack.includes(hint));
    return found ? found[1] : genericFallback;
  }
  window.zoyenPickFallback = pickFallback;
  document.addEventListener('error', function(event){
    const el = event.target;
    if (!el || el.tagName !== 'IMG' || el.dataset.fallbackApplied === '1') return;
    el.dataset.fallbackApplied = '1';
    el.src = pickFallback((el.getAttribute('alt') || '') + ' ' + (el.getAttribute('src') || ''));
  }, true);
  function repairBackgrounds(){
    const nodes = document.querySelectorAll('.slide-bg, .page-hero-bg, [style*="background-image"]');
    nodes.forEach(function(el){
      const bg = getComputedStyle(el).backgroundImage || '';
      const match = bg.match(/url\(["']([^"')]+)["']\)/);
      if (!match) return;
      const original = match[1];
      const probe = new Image();
      probe.onerror = function(){ el.style.backgroundImage = "url('" + pickFallback(original) + "')"; };
      probe.src = original;
    });
  }
  function revealSafety(){ document.querySelectorAll('.reveal').forEach(function(el){ el.classList.add('in'); }); }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function(){ repairBackgrounds(); setTimeout(revealSafety, 700); });
  } else {
    repairBackgrounds(); setTimeout(revealSafety, 700);
  }
  setTimeout(revealSafety, 1800);
})();
</script>
