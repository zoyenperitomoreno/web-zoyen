<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Patagonia Inédita – Tour 6 días · Zoyen Turismo</title>
<link href="https://fonts.googleapis.com/css2family=DM+Serif+Display:ital@0;1&family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
/* Ajuste global de tipografa */
html { font-size: 18px; }

:root {
  --ink:       #1a1410;
  --dark:      #231c14;
  --bark:      #3a2d1f;
  --ember:     #d4772a;
  --ember-dim: #b8621e;
  --amber:     #b87332;
  --sand:      #c9a96e;
  --dust:      #e8dcc8;
  --cream:     #f5f0e8;
  --fog:       #faf7f2;
  --stone:     #7a6a5a;
  --olive:     #5a6040;
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Sora', sans-serif;
  font-size: 16px; line-height: 1.7;
  background: var(--fog); color: var(--ink); overflow-x: hidden;
}

/* NAV */
body > nav:not(.breadcrumb) {
  position: fixed; top: 0; left: 0; right: 0; z-index: 900;
  height: 72px;
  display: grid; grid-template-columns: auto auto 1fr auto;
  align-items: center; padding: 0 2vw; gap: 1rem;
  background: rgba(10,10,10,0.92); backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(212,119,42,0.20);
}
.nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; line-height: 1; flex-shrink: 0; }
.nav-emblem { width: 54px; height: 54px; flex-shrink: 0; }
.nav-logo-text { display: flex; flex-direction: column; gap: 2px; justify-content: center; }
.nav-logo-name { display: flex; align-items: baseline; }
.nav-logo .z { font-family: 'Sora',sans-serif; font-weight: 700; font-size: 1.4rem; letter-spacing: .12em; color: var(--cream); text-transform: uppercase; }
.nav-logo .t { font-family: 'Sora',sans-serif; font-weight: 700; font-size: 1.4rem; letter-spacing: .12em; color: var(--ember); text-transform: uppercase; }
.nav-logo sub { font-size: .60rem; font-weight: 400; letter-spacing: .2em; color: var(--sand); opacity: .65; text-transform: uppercase; display: block; }
.nav-links { display: flex; gap: 1.2rem; list-style: none; align-items: center; justify-content: center; }
.nav-links a { color: rgba(245,240,232,.75); text-decoration: none; font-size: .78rem; font-weight: 500; letter-spacing: .06em; text-transform: uppercase; transition: color .2s; position: relative; white-space: nowrap; }
.nav-links a::after { content:''; position:absolute; bottom:-4px; left:0; right:0; height:1px; background:var(--ember); transform:scaleX(0); transform-origin:left; transition:transform .3s; }
.nav-links a:hover { color: var(--cream); }
.nav-links a:hover::after { transform: scaleX(1); }
.nav-links a.active { color: var(--ember); }
.nav-links a.active::after { transform: scaleX(1); }
.nav-cta-btn { background: var(--ember); color: var(--cream); padding: .5rem 1.3rem; border-radius: 2px; font-family: 'Sora',sans-serif; font-size: .78rem; font-weight: 600; letter-spacing: .15em; text-transform: uppercase; text-decoration: none; white-space: nowrap; flex-shrink: 0; transition: background .2s; }
.nav-cta-btn:hover { background: var(--ember-dim); }

/* HERO */
.page-hero { position: relative; height: 65vh; min-height: 480px; display: flex; align-items: flex-end; padding-bottom: 4rem; overflow: hidden; }
.page-hero-bg { position: absolute; inset: 0; background-image: url('assets/full_inedita.jpg'); background-size: cover; background-position: center; transform: scale(1.04); animation: heroZoom 12s ease-out forwards; }
@keyframes heroZoom { to { transform: scale(1); } }
.page-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(26,20,16,.2) 0%, rgba(26,20,16,.8) 100%); }
.page-hero-content { position: relative; z-index: 2; padding: 0 4vw; color: var(--cream); animation: fadeUp .9s .3s both; }
@keyframes fadeUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:none; } }
.page-hero-eyebrow { font-size: .88rem; font-weight: 700; letter-spacing: .32em; text-transform: uppercase; color: var(--ember); margin-bottom: .8rem; display: inline-flex; align-items: center; gap: 10px; }
.page-hero-eyebrow::before, .page-hero-eyebrow::after { content: ''; width: 22px; height: 1px; background: var(--ember); }
.page-hero-title { font-family: 'DM Serif Display', serif; font-size: clamp(2.4rem, 6vw, 4.5rem); font-weight: 600; line-height: 1.05; text-shadow: 0 2px 20px rgba(26,20,16,.5); }
.page-hero-title em { font-style: italic; color: var(--sand); }
.hero-tags { display: flex; gap: .6rem; flex-wrap: wrap; margin-top: 1.2rem; }
.hero-tag { background: rgba(26,20,16,.6); border: 1px solid rgba(212,119,42,.4); color: var(--dust); padding: .3rem .9rem; border-radius: 1px; font-size: .72rem; font-weight: 600; letter-spacing: .15em; text-transform: uppercase; backdrop-filter: blur(6px); }
.hero-tag.main { background: var(--ember); border-color: var(--ember-dim); }
.breadcrumb { margin-top: .8rem; font-size: .75rem; color: rgba(245,240,232,.5); letter-spacing: .1em; text-transform: uppercase; }
.breadcrumb a { color: rgba(245,240,232,.5); text-decoration: none; }
.breadcrumb a:hover { color: var(--sand); }
.breadcrumb span { color: var(--ember); }

/* REVEAL */
.reveal { opacity: 0; transform: translateY(22px); transition: opacity .75s, transform .75s; }
.reveal.in { opacity: 1; transform: none; }
.reveal-delay { transition-delay: .15s; }
.reveal-delay2 { transition-delay: .28s; }
.eyebrow { font-size: .92rem; font-weight: 600; letter-spacing: .3em; text-transform: uppercase; color: var(--ember); margin-bottom: .5rem; }
.section-title { font-family: 'DM Serif Display', serif; font-size: clamp(1.9rem, 4vw, 3rem); font-weight: 600; line-height: 1.1; color: var(--ink); }
.section-title em { font-style: italic; color: var(--amber); }

/* OVERVIEW STRIP */
.overview-strip {
  background: var(--dark);
  padding: 2.5rem 4vw;
  border-bottom: 1px solid rgba(212,119,42,.2);
}
.overview-inner {
  display: flex; gap: 3rem; flex-wrap: wrap; align-items: center;
  max-width: 1100px; margin: 0 auto;
  justify-content: space-between;
}
.ov-item { text-align: center; }
.ov-num { font-family: 'DM Serif Display', serif; font-size: 2.2rem; font-weight: 600; color: var(--ember); line-height: 1; }
.ov-lbl { font-size: .65rem; font-weight: 600; letter-spacing: .22em; text-transform: uppercase; color: rgba(201,169,110,.6); margin-top: .3rem; }
.ov-sep { width: 1px; height: 48px; background: rgba(212,119,42,.2); }

/* INTRO SECTION */
.tour-intro {
  padding: 5rem 4vw;
  background: var(--fog);
}
.tour-intro-inner {
  display: grid; grid-template-columns: 1.1fr 1fr; gap: 5rem;
  align-items: start; max-width: 1200px; margin: 0 auto;
}
@media (max-width:800px) { .tour-intro-inner { grid-template-columns:1fr; gap:2.5rem; } }
.tour-intro-text p { font-size: 1.02rem; color: var(--stone); line-height: 1.85; font-weight: 300; margin-bottom: 1.2rem; }
.tour-intro-text p strong { color: var(--ink); font-weight: 600; }
.tour-intro-text h2 { margin-bottom: 1.4rem; }
.tour-highlights {
  background: var(--cream);
  border: 1px solid rgba(58,45,31,.1);
  border-top: 3px solid var(--ember);
  border-radius: 3px; padding: 1.8rem;
}
.tour-highlights h3 { font-family: 'DM Serif Display', serif; font-size: 1.2rem; font-weight: 600; color: var(--ink); margin-bottom: 1.2rem; padding-bottom: .8rem; border-bottom: 1px solid rgba(58,45,31,.1); }
.hl-list { list-style: none; display: flex; flex-direction: column; gap: .7rem; }
.hl-list li { display: flex; align-items: flex-start; gap: .8rem; font-size: .96rem; color: var(--stone); line-height: 1.5; }
.hl-list li::before { content: '\2192'; color: var(--ember); font-weight: 700; flex-shrink: 0; margin-top: .1rem; }
.hl-list li strong { color: var(--ink); font-weight: 600; }

/* INCLUYE / NO INCLUYE */
.inc-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
  margin-top: 1.5rem;
}
@media (max-width:600px) { .inc-grid { grid-template-columns:1fr; } }
.inc-card { background: #fff; border: 1px solid rgba(58,45,31,.1); border-radius: 3px; padding: 1.4rem 1.3rem; }
.inc-card h4 { font-size: .75rem; font-weight: 700; letter-spacing: .22em; text-transform: uppercase; margin-bottom: .9rem; padding-bottom: .6rem; border-bottom: 1px solid rgba(58,45,31,.08); }
.inc-card.yes h4 { color: var(--olive); }
.inc-card.no h4 { color: var(--stone); }
.inc-list { list-style: none; display: flex; flex-direction: column; gap: .5rem; }
.inc-list li { font-size: .88rem; color: var(--stone); display: flex; gap: .6rem; align-items: flex-start; }
.inc-list li span.ico { flex-shrink: 0; }

.itinerario-head { display:flex; align-items:flex-end; justify-content:space-between; gap:1.5rem; margin-bottom:3.5rem; flex-wrap:wrap; }
.itinerario-head .reveal { margin-bottom:0 !important; }
.download-pdf-btn {
  display:inline-flex; align-items:center; gap:.55rem;
  background:var(--ember); color:var(--cream);
  padding:.78rem 1.25rem; border-radius:2px;
  text-decoration:none; font-size:.76rem; font-weight:700;
  letter-spacing:.14em; text-transform:uppercase;
  box-shadow:0 10px 24px rgba(212,119,42,.22);
  transition:background .2s, transform .2s, box-shadow .2s;
}
.download-pdf-btn:hover { background:var(--ember-dim); transform:translateY(-1px); box-shadow:0 14px 30px rgba(212,119,42,.28); }
.download-pdf-btn::before { content:'PDF'; font-size:.62rem; letter-spacing:.08em; border:1px solid rgba(245,240,232,.55); padding:.12rem .28rem; }
@media(max-width:640px){ .itinerario-head { align-items:flex-start; } .download-pdf-btn { width:100%; justify-content:center; } }
/* ITINERARIO */
.itinerario-section {
  padding: 5rem 4vw;
  background: var(--cream);
  border-top: 1px solid rgba(58,45,31,.08);
}
.itinerario-inner { max-width: 900px; margin: 0 auto; }
.dia-block {
  display: grid; grid-template-columns: 80px 1fr; gap: 0;
  margin-bottom: 0;
  position: relative;
}
.dia-block:not(:last-child)::before {
  content: '';
  position: absolute;
  left: 39px; top: 48px; bottom: 0;
  width: 2px;
  background: linear-gradient(to bottom, var(--ember), rgba(212,119,42,.15));
}
.dia-num {
  display: flex; flex-direction: column; align-items: center; padding-top: .5rem;
  position: relative; z-index: 1;
}
.dia-circle {
  width: 42px; height: 42px; border-radius: 50%;
  background: var(--ember); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-family: 'DM Serif Display', serif; font-size: 1.1rem; font-weight: 600;
  box-shadow: 0 4px 16px rgba(212,119,42,.4);
  flex-shrink: 0;
}
.dia-content {
  padding: .3rem 0 3rem 1.8rem;
}
.dia-label { font-size: .65rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--ember); margin-bottom: .4rem; }
.dia-title { font-family: 'DM Serif Display', serif; font-size: 1.4rem; font-weight: 600; color: var(--ink); margin-bottom: .8rem; line-height: 1.2; }
.dia-title em { font-style: italic; color: var(--amber); }
.dia-desc { font-size: .97rem; color: var(--stone); line-height: 1.85; font-weight: 300; }
.dia-desc strong { color: var(--ink); font-weight: 600; }
.dia-img { width: 100%; border-radius: 3px; margin-top: 1.2rem; aspect-ratio: 16/7; object-fit: cover; box-shadow: 0 8px 32px rgba(26,20,16,.12); }
.dia-chips { display: flex; gap: .5rem; flex-wrap: wrap; margin-top: 1rem; }
.dia-chip { font-size: .65rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; background: rgba(58,45,31,.07); color: var(--stone); padding: .25rem .75rem; border-radius: 999px; border: 1px solid rgba(58,45,31,.12); }

/* GALERIA */
.galeria-section { padding: 5rem 4vw; background: var(--fog); }
.galeria-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: .8rem; margin-top: 3rem; }
@media (max-width:700px) { .galeria-grid { grid-template-columns: 1fr 1fr; } }
.galeria-grid img { width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: 2px; transition: transform .4s, box-shadow .4s; cursor: pointer; }
.galeria-grid img:hover { transform: scale(1.03); box-shadow: 0 16px 40px rgba(26,20,16,.18); }
.galeria-grid img:first-child { grid-column: span 2; aspect-ratio: 16/7; }

/* CTA */
.tour-cta { background: var(--dark); padding: 5rem 4vw; text-align: center; border-top: 1px solid rgba(212,119,42,.2); }
.tour-cta h2 { font-family: 'DM Serif Display', serif; font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 600; color: var(--dust); margin-bottom: 1rem; }
.tour-cta h2 em { font-style: italic; color: var(--sand); }
.tour-cta p { font-size: 1.02rem; color: rgba(232,220,200,.55); max-width: 480px; margin: 0 auto 2.5rem; font-weight: 300; line-height: 1.8; }
.cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.cta-btn-p { background: var(--ember); color: var(--cream); padding: .85rem 2.2rem; border-radius: 2px; text-decoration: none; font-size: .93rem; font-weight: 600; letter-spacing: .18em; text-transform: uppercase; transition: background .2s; }
.cta-btn-p:hover { background: var(--ember-dim); }
.cta-btn-g { border: 1px solid rgba(245,240,232,.3); color: rgba(245,240,232,.7); padding: .85rem 2.2rem; border-radius: 2px; text-decoration: none; font-size: .93rem; font-weight: 600; letter-spacing: .18em; text-transform: uppercase; transition: border-color .2s, color .2s; background: transparent; }
.cta-btn-g:hover { border-color: var(--sand); color: var(--sand); }

/* FOOTER */
footer { background: #0a0a0a; padding: 5rem 3vw 2.5rem; }
.footer-top { display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: 3rem; padding-bottom: 3rem; border-bottom: 1px solid rgba(212,119,42,.15); margin-bottom: 2rem; }
@media (max-width:700px){ .footer-top { grid-template-columns: 1fr; gap: 2rem; } }
.footer-brand-wrap { display: flex; align-items: center; gap: 12px; margin-bottom: .6rem; }
.footer-emblem { width: 48px; height: 48px; flex-shrink: 0; }
.footer-brand { font-family: 'Sora',sans-serif; font-size: 1.5rem; font-weight: 700; letter-spacing: .1em; }
.footer-brand span.footer-brand-zoyen { color: #fff; }
.footer-brand span { color: var(--ember); }
.footer-tagline { font-size: 1.05rem; color: rgba(232,220,200,.65); line-height: 1.7; margin-bottom: 1.4rem; font-weight: 300; }
.socials { display: flex; gap: .6rem; }
.social-btn { width: 34px; height: 34px; border-radius: 1px; border: 1px solid rgba(201,169,110,.2); color: var(--sand); text-decoration: none; display: flex; align-items: center; justify-content: center; transition: border-color .2s, background .2s; }
.social-btn svg { display: block; }
.social-btn:hover { border-color: var(--ember); background: rgba(212,119,42,.12); }
.footer-col-title { font-size: 1rem; font-weight: 600; letter-spacing: .25em; text-transform: uppercase; color: var(--ember); margin-bottom: 1.1rem; }
.footer-links { list-style: none; display: flex; flex-direction: column; gap: .55rem; }
.footer-links a { color: rgba(232,220,200,.70); text-decoration: none; font-size: .8rem; font-weight: 300; transition: color .2s; display: flex; align-items: center; gap: 7px; }
.footer-links a::before { content: '–'; color: var(--ember); opacity: .5; }
.footer-links a:hover { color: var(--sand); }
.footer-contact { font-size: .8rem; color: rgba(232,220,200,.70); line-height: 1.8; font-weight: 300; }
.footer-contact strong { color: var(--sand); font-weight: 500; }
.footer-bottom { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: .5rem; font-size: .93rem; color: rgba(232,220,200,.40); letter-spacing: .08em; }
.footer-bottom a { color: rgba(201,169,110,.55); text-decoration: none; }

.wa { position: fixed; bottom: 1.8rem; right: 1.8rem; z-index: 800; width: 52px; height: 52px; border-radius: 50%; background: #25d366; color: #fff; display: flex; align-items: center; justify-content: center; text-decoration: none; box-shadow: 0 4px 20px rgba(37,211,102,.35); transition: transform .25s; }
.wa:hover { transform: scale(1.1); }
.wa svg { width: 26px; height: 26px; }

@media (max-width:760px) { .nav-links { display: none; } }

/* LANGUAGE SWITCHER */
.lang-switcher { position: relative; justify-self: start; z-index: 920; }
.lang-current {
  min-width: 116px; height: 34px;
  display: inline-flex; align-items: center; justify-content: space-between; gap: .55rem;
  padding: 0 .7rem;
  border: 1px solid rgba(212,119,42,.34); border-radius: 2px;
  background: rgba(245,240,232,.06); color: rgba(245,240,232,.78);
  font-family: 'Sora', sans-serif; font-size: .68rem; font-weight: 700;
  letter-spacing: .08em; text-transform: uppercase; cursor: pointer;
  transition: border-color .2s, background .2s, color .2s;
}
.lang-current:hover,
.lang-switcher.open .lang-current { color: var(--cream); border-color: rgba(212,119,42,.65); background: rgba(212,119,42,.12); }
.lang-current::after {
  content: ''; width: 6px; height: 6px;
  border-right: 1px solid currentColor; border-bottom: 1px solid currentColor;
  transform: translateY(-2px) rotate(45deg); transition: transform .2s;
}
.lang-switcher.open .lang-current::after { transform: translateY(1px) rotate(225deg); }
.lang-menu {
  position: absolute; top: calc(100% + 8px); left: 0; min-width: 168px;
  padding: 6px; list-style: none;
  background: rgba(10,10,10,.96);
  border: 1px solid rgba(212,119,42,.28); border-radius: 2px;
  box-shadow: 0 14px 36px rgba(0,0,0,.35);
  opacity: 0; visibility: hidden; transform: translateY(-6px);
  transition: opacity .18s, transform .18s, visibility .18s;
}
.lang-switcher.open .lang-menu { opacity: 1; visibility: visible; transform: translateY(0); }
.lang-btn {
  width: 100%; display: flex; align-items: center; justify-content: space-between; gap: .75rem;
  padding: .55rem .65rem; border: 0; border-radius: 1px;
  background: transparent; color: rgba(245,240,232,.68);
  font-family: 'Sora', sans-serif; font-size: .7rem; font-weight: 600;
  letter-spacing: .04em; cursor: pointer; text-align: left;
  transition: background .2s, color .2s;
}
.lang-btn:hover { color: var(--cream); background: rgba(212,119,42,.16); }
.lang-btn.active { background: var(--ember); color: var(--cream); }
.lang-code { color: rgba(245,240,232,.45); font-size: .58rem; font-weight: 800; letter-spacing: .1em; }
.lang-btn.active .lang-code { color: rgba(255,255,255,.82); }
@media (min-width: 961px) and (max-width: 1360px) {
  nav { column-gap: .75rem; }
  .nav-emblem { width: 46px; height: 46px; }
  .nav-logo { gap: 8px; }
  .nav-logo .z, .nav-logo .t { font-size: 1.08rem; letter-spacing: .09em; }
  .nav-logo sub { display: none; }
  .nav-links { gap: .72rem; }
  .nav-links a { font-size: .64rem; letter-spacing: .035em; }
  .lang-current { min-width: 98px; height: 31px; padding: 0 .55rem; font-size: .58rem; }
  .lang-menu { min-width: 150px; }
  .lang-btn { padding: .5rem .58rem; font-size: .64rem; }
  .nav-cta-btn { padding: .45rem .85rem; font-size: .66rem; letter-spacing: .1em; }
}
@media (max-width: 640px) {
  .nav-cta-btn { display: none; }
  .lang-switcher { margin-left: auto; justify-self: end; }
  .lang-current { min-width: 104px; height: 32px; padding: 0 .55rem; font-size: .58rem; }
  .lang-menu { left: auto; right: 0; min-width: 150px; }
  .lang-btn { padding: .52rem .58rem; font-size: .64rem; }
  .nav-emblem { width: 40px; height: 40px; }
  .nav-logo { gap: 6px; }
  .nav-logo .z, .nav-logo .t { font-size: .98rem; letter-spacing: .08em; }
  .nav-logo sub { display: none; }
}

/* NAV CONTACT + ZOYI ASSISTANT */
.nav-actions {
  display: flex;
  align-items: center;
  justify-self: end;
  gap: .55rem;
  min-width: 0;
}
.nav-contact-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: .45rem;
  min-height: 36px;
  padding: .48rem .95rem;
  border: 1px solid rgba(37,211,102,.58);
  border-radius: 2px;
  background: rgba(37,211,102,.10);
  color: var(--cream);
  font-family: 'Sora', sans-serif;
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .11em;
  line-height: 1;
  text-transform: uppercase;
  text-decoration: none;
  white-space: nowrap;
  transition: background .2s, border-color .2s, color .2s, transform .2s;
}
.nav-contact-btn svg { width: 16px; height: 16px; fill: currentColor; flex: 0 0 auto; }
.nav-contact-btn:hover { background: #25d366; border-color: #25d366; color: #122118; transform: translateY(-1px); }
.zoyi-widget {
  position: fixed;
  right: 22px;
  bottom: 22px;
  z-index: 1600;
  font-family: 'Sora', sans-serif;
}
.zoyi-toggle {
  min-width: 112px;
  height: 54px;
  border: 1px solid rgba(212,119,42,.58);
  border-radius: 999px;
  background: rgba(26,20,16,.92);
  color: var(--cream);
  box-shadow: 0 18px 42px rgba(0,0,0,.32);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: .55rem;
  cursor: pointer;
